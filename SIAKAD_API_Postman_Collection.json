					"name": "Get Users",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/users",
							"host": ["{{base_url}}"],
							"path": ["users"]
						},
						"description": "### Get Users\n\n`STATUS: PRODUCTION`\n\nEndpoint untuk mengambil daftar pengguna terdaftar."
					},
					"response": [
						{
							"name": "200 OK - Success",
							"originalRequest": {
								"method": "GET",
								"header": [],
								"url": "{{base_url}}/users"
							},
							"status": "OK",
							"code": 200,
							"body": "{\n  \"success\": true,\n  \"message\": \"Data User Berhasil Diambil\",\n  \"data\": [\n    {\n      \"id\": 1,\n      \"name\": \"Admin\",\n      \"email\": \"admin@uhb.ac.id\",\n      \"created_at\": \"2026-01-15T08:00:00.000000Z\"\n    }\n  ]\n}"
